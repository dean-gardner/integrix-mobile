# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY variable contains the PATH to the node executable.
#
# Customize the NODE_BINARY variable here.
# For example, to use nvm with brew, add the following line
# . "$(brew --prefix nvm)/nvm.sh" --no-use
export NODE_BINARY=$(command -v node)

# Hermes CLI path is injected by CocoaPods from `require.resolve("hermes-compiler")` at **pod install** time.
# If the folder was ever renamed (e.g. dean_gardner vs dean-gardner) or you use a different checkout path,
# that cached path breaks Archive with: hermesc: No such file or directory.
# `react-native-xcode.sh` only sets HERMES_CLI_PATH when it is empty, so we must clear a stale value first.
unset HERMES_CLI_PATH 2>/dev/null || true

# Xcode sets PROJECT_DIR to the ios/ folder during script phases.
_IOS_DIR="${PROJECT_DIR:-}"
if [ -z "$_IOS_DIR" ] && [ -n "${BASH_SOURCE[0]:-}" ]; then
  _IOS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi
if [ -n "$_IOS_DIR" ]; then
  _REPO_ROOT="$(cd "$_IOS_DIR/.." && pwd)"
  _HERMES_NPM="$_REPO_ROOT/node_modules/hermes-compiler/hermesc/osx-bin/hermesc"
  _PODS="${PODS_ROOT:-$_IOS_DIR/Pods}"
  _HERMES_POD="$_PODS/hermes-engine/destroot/bin/hermesc"
  if [ -x "$_HERMES_NPM" ]; then
    export HERMES_CLI_PATH="$_HERMES_NPM"
  elif [ -x "$_HERMES_POD" ]; then
    export HERMES_CLI_PATH="$_HERMES_POD"
  fi
fi
# If still unset, react-native-xcode.sh will set HERMES_CLI_PATH="$PODS_ROOT/hermes-engine/destroot/bin/hermesc".
